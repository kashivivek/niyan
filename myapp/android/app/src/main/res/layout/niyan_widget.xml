<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Widget header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Pending Rents"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/last_updated"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Updated now"
            android:textColor="#80FFFFFF"
            android:textSize="9sp" />
    </LinearLayout>

    <!-- Divider -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:background="#33FFFFFF" />

    <!-- Overdue section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <!-- Accent bar using TextView (View is not RemoteViews-safe) -->
        <TextView
            android:layout_width="4dp"
            android:layout_height="34dp"
            android:background="#FF5252"
            android:layout_marginEnd="10dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OVERDUE"
                android:textColor="#FF5252"
                android:textSize="8sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/overdue_details"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No overdue rents"
                android:textColor="#CCFFFFFF"
                android:textSize="11sp"
                android:maxLines="3"
                android:ellipsize="end" />
        </LinearLayout>

        <TextView
            android:id="@+id/overdue_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#FF5252"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- Divider -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginBottom="6dp"
        android:background="#22FFFFFF" />

    <!-- Upcoming section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Accent bar using TextView -->
        <TextView
            android:layout_width="4dp"
            android:layout_height="34dp"
            android:background="#448AFF"
            android:layout_marginEnd="10dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UPCOMING"
                android:textColor="#448AFF"
                android:textSize="8sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/upcoming_details"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No upcoming rents"
                android:textColor="#CCFFFFFF"
                android:textSize="11sp"
                android:maxLines="3"
                android:ellipsize="end" />
        </LinearLayout>

        <TextView
            android:id="@+id/upcoming_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#448AFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp" />
    </LinearLayout>

</LinearLayout>
